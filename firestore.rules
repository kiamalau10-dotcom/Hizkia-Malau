rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users_by_uid/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users_by_uid/$(request.auth.uid)).data.role.upper() == 'ADMIN';
    }

    function isOwner(username) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users_by_uid/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users_by_uid/$(request.auth.uid)).data.username == username;
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.role in ['ADMIN', 'USER', 'admin', 'user'];
    }

    // Rules
    
    match /users/{username} {
      allow read: if true; 
      allow create: if isValidUser(request.resource.data);
      allow update: if (isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin())) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginDate', 'streak', 'streakFreezeCount', 'lastActive', 'uid', 'currentExp', 'level', 'coins', 'quizHistory', 'achievements', 'ownedItems', 'avatarConfig', 'equippedCostumeId', 'voxTitle', 'needsStreakProtection', 'previousStreak', 'displayName', 'username', 'role', 'password']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if true; // Allow creation for unauthenticated users if Anonymous Auth is disabled
      allow update: if true;
      allow delete: if isAdmin() || (isAuthenticated() && (
        (resource.data.authorId == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users_by_uid/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users_by_uid/$(request.auth.uid)).data.username == resource.data.username)
      )) || (request.auth == null);
    }

    match /users_by_uid/{uid} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if true;
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if true;
      allow delete: if isAdmin();
    }

    match /quiz_results/{resultId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if true;
      allow delete: if isAdmin();
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create: if true;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
